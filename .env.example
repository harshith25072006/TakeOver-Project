# =============================================================================
# DAZZ Manager - environment template. Copy to .env and fill in real values.
#   cp .env.example .env
# Only DATABASE_URL and AUTH_SECRET are strictly required; the rest enable optional
# features and are validated (when set) at startup by src/lib/env.ts.
# =============================================================================

# --- Database (required) ---
# Local dev with docker-compose:
DATABASE_URL="postgresql://dazz:dazz_dev_password@localhost:5432/dazz_manager?schema=public"

# --- Auth.js v5 (required) ---
# Signing secret for session JWTs. The app refuses to start if this is unset.
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
# Trust the incoming Host header (needed behind a proxy / on most hosts).
AUTH_TRUST_HOST="true"

# --- Cron (optional) ---
# Bearer token for POST /api/cron/reset-payments and /api/cron/rent-reminders. Both
# endpoints fail closed (always 401) until this is set. Generate with:
# openssl rand -base64 32
CRON_SECRET="replace-with-a-strong-random-secret"

# --- Server Actions allowed origins (optional) ---
# Comma-separated hostnames (besides the app's own origin) allowed to invoke Server
# Actions. Set to your public host(s) in production; leave blank in local dev.
#   ALLOWED_ORIGINS="app.example.com,admin.example.com"
ALLOWED_ORIGINS=""

# --- File storage (optional; sensible defaults shown) ---
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage/uploads"
STORAGE_MAX_FILE_MB="10"

# --- Public base URL (required only for WhatsApp invoice delivery) ---
# Twilio fetches the invoice PDF from this URL, so it MUST be publicly reachable.
# localhost will NOT work (Twilio runs in the cloud) and is rejected with a clear error.
# In development, expose the dev server with a tunnel (e.g. `ngrok http 3000`) and set
# this to the public https URL it prints, then RESTART the server.
APP_PUBLIC_URL="https://your-public-host.example.com"

# --- Twilio (required only for WhatsApp invoice delivery) ---
# Server-only — never exposed to the client.
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# WhatsApp-enabled sender in E.164, e.g. the Twilio sandbox number.
TWILIO_WHATSAPP_NUMBER="+14155238886"

# --- AiSensy (optional; template-based WhatsApp: rent reminders, complaint-resolved
# notices, credential delivery) ---
# The JWT API key from AiSensy > Manage > API.
AISENSY_API_KEY=""
# Exact campaign names configured (and template-approved) in your AiSensy dashboard.
# These are placeholders — replace with your real campaign names.
AISENSY_CAMPAIGN_RENT_REMINDER="rent_reminder"
AISENSY_CAMPAIGN_COMPLAINT_RESOLVED="complaint_resolved"
AISENSY_CAMPAIGN_CREDENTIALS="account_credentials"

# --- Exotel (optional; required only for the Collections "AI Call" button) ---
# Server-only — never exposed to the client. From Exotel dashboard > Settings > API Settings.
EXOTEL_ACCOUNT_SID="your-exotel-account-sid"
EXOTEL_API_KEY="your-exotel-api-key"
EXOTEL_API_TOKEN="your-exotel-api-token"
EXOTEL_SUBDOMAIN="api.exotel.com"
# The ExoPhone (virtual number) purchased in your Exotel account, shown as caller ID.
EXOTEL_CALLER_ID="0XXXXXXXXXX"
# App Bazaar app id for a Flow you build once in the Exotel dashboard: App Bazaar ->
# Custom Apps -> Create -> add a Greeting applet with "Type Text" set to a URL
# (= {APP_PUBLIC_URL}/api/calls/exoml) -> connect a Hangup applet after it -> Save.
# The app id shows up in the Custom Apps table's APP ID column.
EXOTEL_APP_ID="your-app-id"
