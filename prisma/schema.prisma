// DAZZ Manager - PG Management System
// Prisma 7 schema. The datasource URL is supplied via prisma.config.ts (reads .env).
// Client is generated into src/generated/prisma (see generator below).
//
// Money convention: all monetary amounts are stored as integer PAISE (1 rupee = 100
// paise) to avoid floating-point errors and Decimal serialization issues across the
// React Server Component boundary. Use src/lib/money.ts helpers to convert/format.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Enums
// ============================================================================

enum Role {
  APP_OWNER
  PROPERTY_OWNER
  MANAGER
  TENANT
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
}

enum TenancyStatus {
  ACTIVE
  ENDED
}

enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
}

enum PaymentMethod {
  CASH
  ONLINE
  SPLIT
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum DepositStatus {
  PENDING
  REFUNDABLE
  FORFEITED
  ADJUSTED
}

enum DocumentType {
  AADHAAR_FRONT
  AADHAAR_BACK
  PAN
  PHOTO
  AGREEMENT
  OTHER
}

enum InvoiceStatus {
  SENT
  FAILED
}

enum CallStatus {
  CALLING
  CONNECTED
  COMPLETED
  FAILED
}

// ============================================================================
// Auth (Auth.js v5). Credentials + JWT today; Account/Session/VerificationToken
// included to future-proof OAuth and the owner dashboard.
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  phone         String? // for WhatsApp credential/invitation delivery (AiSensy)
  role          Role      @default(TENANT)
  isActive      Boolean   @default(true)
  // MANAGER and TENANT accounts are scoped to a single property (their PG).
  // APP_OWNER leaves this null and can access every property. PROPERTY_OWNER also
  // leaves this null and instead accesses properties via `ownedProperties` below.
  // onDelete: SetNull so hard-deleting a property never deletes the human;
  // deactivation is the reversible path.
  propertyId    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  property           Property?   @relation("PropertyStaff", fields: [propertyId], references: [id], onDelete: SetNull)
  ownedProperties    PropertyOwnership[]
  tenant             Tenant?
  accounts           Account[]
  sessions           Session[]
  assignedComplaints    Complaint[] @relation("ComplaintAssignee")
  createdExpenses       Expense[]
  recordedPayments      Payment[]   @relation("PaymentRecorder")

  @@index([role])
  @@index([propertyId])
}

// Join model: a PROPERTY_OWNER can own multiple properties (unlike MANAGER/TENANT
// which are pinned to one via User.propertyId).
model PropertyOwnership {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================================
// Property structure
// ============================================================================

model Property {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  city      String?
  phone     String? // contact number shown on invoices
  // Storage key (not a public URL) of the property's own logo, served through the
  // authenticated /api/files route. Used on invoices and in the app chrome; falls back
  // to the DAZZ brand logo when null. See src/lib/storage.ts.
  logoKey   String?
  // When true the property is organised into blocks (e.g. Frieden A / B) and the
  // Floor Manager shows a Block selector before the Floor selector.
  hasBlocks Boolean  @default(false)
  // When true the property rents self-contained flats/studios (no per-bed sharing),
  // so the UI shows "Flat <number>" instead of "Room <number> · Bed <label>".
  isFlat    Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]          @relation("PropertyStaff")
  blocks         Block[]
  floors         Floor[]
  rooms          Room[]
  beds           Bed[]
  tenants        Tenant[]
  tenancies      Tenancy[]
  payments       Payment[]
  complaints     Complaint[]
  expenses       Expense[]
  floorTemplates FloorTemplate[]
  invoices       Invoice[]
  calls          Call[]

  expenseCategories    ExpenseCategory[]
  expenseSubcategories ExpenseSubcategory[]
  owners               PropertyOwnership[]

  @@index([isActive])
}

model Block {
  id         String   @id @default(cuid())
  propertyId String
  name       String // "A", "B"
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floors   Floor[]

  @@unique([propertyId, name])
  @@index([propertyId])
}

// Reusable floor layout. Lets a property define a layout once (e.g. "14 rooms,
// mixed sharing") and instantiate it onto many identical floors without
// duplicating room definitions by hand.
model FloorTemplate {
  id          String   @id @default(cuid())
  propertyId  String
  name        String // "Standard Residential Floor"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property      Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  roomTemplates RoomTemplate[]
  floors        Floor[] // floors generated from this template

  @@index([propertyId])
}

model RoomTemplate {
  id              String   @id @default(cuid())
  floorTemplateId String
  sequence        Int // 1-based position on the floor; used to compute the room number
  label           String?
  sharingType     Int // number of beds in this room
  createdAt       DateTime @default(now())

  floorTemplate FloorTemplate @relation(fields: [floorTemplateId], references: [id], onDelete: Cascade)

  @@unique([floorTemplateId, sequence])
  @@index([floorTemplateId])
}

model Floor {
  id         String   @id @default(cuid())
  propertyId String
  blockId    String?
  templateId String? // template this floor was generated from (for reference/regen)
  number     Int // floor number (e.g. 3, 4, 5)
  name       String? // optional display name
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property       @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  block    Block?         @relation(fields: [blockId], references: [id], onDelete: Cascade)
  template FloorTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  rooms    Room[]

  @@unique([propertyId, blockId, number])
  @@index([propertyId])
  @@index([blockId])
}

model Room {
  id          String   @id @default(cuid())
  propertyId  String
  floorId     String
  number      String // "301"
  label       String?
  sharingType Int // configured number of beds; kept in sync with beds by admin actions
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floor      Floor       @relation(fields: [floorId], references: [id], onDelete: Cascade)
  beds       Bed[]
  complaints Complaint[]

  @@unique([propertyId, number])
  @@index([floorId])
  @@index([propertyId])
}

model Bed {
  id         String    @id @default(cuid())
  propertyId String // denormalized for fast property-scoped occupancy queries
  roomId     String
  label      String // "A", "B", "1" - bed identifier within the room
  status     BedStatus @default(AVAILABLE)
  order      Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  property  Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tenancies Tenancy[] // history; the active occupant is the tenancy with status ACTIVE

  @@unique([roomId, label])
  @@index([roomId])
  @@index([propertyId])
  @@index([status])
}

// ============================================================================
// People & occupancy
// ============================================================================

model Tenant {
  id               String   @id @default(cuid())
  propertyId       String
  // Optional portal login for this resident. User.role = TENANT, User.propertyId
  // pinned to the same property. onDelete: SetNull so removing the login account
  // never deletes tenant history.
  userId           String?  @unique
  fullName         String
  phone            String
  email            String?
  emergencyContact String?
  fatherName       String?
  motherName       String?
  address          String?
  aadhaarNumber    String?
  panNumber        String?
  college          String?
  company          String?
  occupation       String?
  notes            String?
  photoUrl         String? // primary KYC photo storage key (convenience denormalization)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenancies  Tenancy[]
  documents  Document[]
  payments   Payment[]
  complaints Complaint[]
  invoices   Invoice[]
  calls      Call[]

  @@index([propertyId])
  @@index([phone])
}

// A single occupancy of a bed by a tenant. Vacating a bed ends the tenancy
// (status ENDED, checkOutDate set) rather than deleting it, preserving history.
model Tenancy {
  id                  String        @id @default(cuid())
  propertyId          String
  tenantId            String
  bedId               String
  roomId              String // denormalized for queries
  status              TenancyStatus @default(ACTIVE)
  monthlyRent         Int // paise
  maintenanceCharge   Int           @default(0) // paise; extra monthly charge on top of rent
  securityDeposit     Int? // paise; net of the maintenance reserve deducted at move-in
  depositStatus       DepositStatus @default(PENDING)
  paymentStatus       PaymentStatus @default(PENDING) // current-cycle snapshot shown on the bed
  paymentDueDay       Int? // day of month rent is due (1-31)
  checkInDate         DateTime
  noticeGivenDate     DateTime? // when the tenant gave notice; vacate-by is +15 days
  expectedLeavingDate DateTime?
  checkOutDate        DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  property Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bed      Bed       @relation(fields: [bedId], references: [id], onDelete: Cascade)
  payments Payment[]
  invoices Invoice[]

  @@index([propertyId])
  @@index([bedId, status])
  @@index([tenantId])
  @@index([status])
}

model Payment {
  id         String        @id @default(cuid())
  propertyId String
  tenancyId  String
  tenantId   String
  amount     Int // paise
  forMonth   DateTime // first day of the month this payment covers
  status     PaymentStatus @default(PAID)
  method     PaymentMethod @default(CASH)
  cashAmount Int?          // paise
  onlineAmount Int?        // paise
  paidAt     DateTime?
  notes      String?
  recordedById String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancy  Tenancy  @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recordedBy User?  @relation("PaymentRecorder", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([tenancyId])
  @@index([tenantId])
  @@index([forMonth])
}

model Document {
  id         String       @id @default(cuid())
  tenantId   String
  type       DocumentType @default(OTHER)
  storageKey String // path within the storage driver, NOT a public URL
  filename   String
  mimeType   String
  size       Int // bytes
  createdAt  DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// A generated rent invoice. The charge breakdown is snapshotted in paise at send
// time so historical invoices stay accurate even if the tenancy's rent later
// changes. The PDF lives in the storage driver (storageKey), never a public URL.
model Invoice {
  id                String        @id @default(cuid())
  propertyId        String
  tenancyId         String
  tenantId          String // denormalized so history survives tenancy/tenant edits
  number            String // human-facing, e.g. "INV-202606-0001"; unique per property
  billingMonth      DateTime // first day of the billed month
  issueDate         DateTime      @default(now())
  dueDate           DateTime?
  rentPaise         Int
  maintenancePaise  Int           @default(0)
  previousDuePaise  Int           @default(0)
  extraChargesPaise Int           @default(0)
  extraChargesLabel String?
  discountPaise     Int           @default(0)
  subtotalPaise     Int
  totalPaise        Int
  notes             String?
  storageKey        String // PDF path within the storage driver
  status            InvoiceStatus @default(SENT)
  messageSid        String? // Twilio WhatsApp message SID
  sentAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenancy  Tenancy  @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, number])
  @@index([propertyId])
  @@index([tenancyId])
  @@index([tenantId])
  @@index([billingMonth])
}

// An outbound AI/test call placed via Exotel. One row per call attempt, tracked
// from initiation through Exotel's StatusCallback webhook so the UI can poll for
// live status without holding any Exotel credentials client-side.
model Call {
  id         String     @id @default(cuid())
  propertyId String
  tenantId   String
  phone      String
  message    String
  callSid    String?    @unique // Exotel Call Sid; null until the API call succeeds
  status     CallStatus @default(CALLING)
  error      String? // Exotel's error message, when status = FAILED
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
}

// ============================================================================
// Operations
// ============================================================================

model Complaint {
  id           String            @id @default(cuid())
  propertyId   String
  title        String
  description  String?
  status       ComplaintStatus   @default(OPEN)
  priority     ComplaintPriority @default(MEDIUM)
  assignedToId String?
  tenantId     String?
  roomId       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  resolvedAt   DateTime?

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  assignedTo User?    @relation("ComplaintAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  room       Room?    @relation(fields: [roomId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([status])
  @@index([priority])
  @@index([assignedToId])
}

model Expense {
  id            String   @id @default(cuid())
  propertyId    String
  categoryId    String
  subcategoryId String?
  amount        Int // paise
  date          DateTime
  vendor        String?
  notes         String?
  receiptKey    String? // storage key for the receipt file
  createdById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property    Property            @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  category    ExpenseCategory     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory ExpenseSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: Restrict)
  createdBy   User?               @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([date])
}

// Property-scoped expense category (replaces the old hardcoded ExpenseCategory
// enum). Deleting a category is blocked by the DB while any expense references it
// (onDelete: Restrict on Expense.category) and cascades to its subcategories.
model ExpenseCategory {
  id         String   @id @default(cuid())
  propertyId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property      Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  subcategories ExpenseSubcategory[]
  expenses      Expense[]

  @@unique([propertyId, name])
  @@index([propertyId])
}

model ExpenseSubcategory {
  id         String   @id @default(cuid())
  propertyId String // denormalized for property-scoped queries
  categoryId String
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@index([propertyId])
}
